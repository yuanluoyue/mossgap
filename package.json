{
  "name": "mossgap",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "clean": "node -e \"const fs=require('fs');['.next','.open-next'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build:deploy": "pnpm db:setup:remote && next build && opennextjs-cloudflare build --skipNextBuild",
    "start": "next start",
    "lint": "eslint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "pnpm db:setup:remote && wrangler deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:local": "wrangler d1 migrations apply mossgap --local",
    "db:migrate:remote": "wrangler d1 migrations apply mossgap --remote",
    "db:setup:remote": "pnpm db:migrate:remote && pnpm db:seed:remote && wrangler d1 execute mossgap --remote --file=seed-remote.sql",
    "db:seed:local": "tsx scripts/seed.ts --local",
    "db:seed:remote": "tsx scripts/seed.ts --remote",
    "oss:create-bucket": "tsx scripts/create-bucket.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@next/third-parties": "^16.2.10",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "fflate": "^0.8.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "wrangler": "^4.107.0"
  }
}
