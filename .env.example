# ===== S3 兼容对象存储 =====
# 本地开发用 MinIO；生产用 Cloudflare R2（S3 兼容 endpoint）

# 本地 MinIO（docker-compose.dev.yml 已配置）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=mossgap-games
# key 前缀，所有对象会存储在此前缀下（留空则直接存到 bucket 根目录）
S3_KEY_PREFIX=
# MinIO 公共访问域名（path-style），格式：http://<host>:<port>/<bucket>
S3_PUBLIC_URL=http://localhost:9000/mossgap-games
# MinIO 必须开启 path-style
S3_FORCE_PATH_STYLE=true
# OSS 适配器：aws-sdk（默认，使用 @aws-sdk/client-s3）| custom（手写签名）
OSS_ADAPTER=aws-sdk

# 生产 Cloudflare R2 示例（取消注释并替换为实际值）
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY_ID=your_r2_access_key
# S3_SECRET_ACCESS_KEY=your_r2_secret_key
# S3_BUCKET=your_r2_bucket
# S3_KEY_PREFIX=uploads/2024
# S3_PUBLIC_URL=https://pub-xxxxxx.r2.dev
# S3_FORCE_PATH_STYLE=false

# ===== Admin 认证 =====
# 注意：admin 账号存数据库 admins 表，通过 `pnpm db:seed:local` 初始化（默认 admin/123456）。
# 此处仅配置 JWT 签名密钥，请使用足够长的随机字符串。
JWT_SECRET=changeme-to-a-long-random-string

# ===== 应用 =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Google Analytics 4（可选） =====
# 留空则不加载 GA 脚本；填入 G-XXXXXXXXXX 格式的 Measurement ID 即可启用
NEXT_PUBLIC_GA_MEASUREMENT_ID=
